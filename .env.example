OPENAI_API_KEY=sk-...
OPENAI_LLM_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=1536

DATABASE_URL=postgresql+asyncpg://raguser:ragpass@localhost:5432/ragdb

AWS_REGION=ap-southeast-2
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...
S3_BUCKET_NAME=rag-system-docs-dev

APP_ENV=development
ADMIN_API_KEY=change-me-strong-random-key
LOG_LEVEL=INFO
MAX_RETRIEVAL_K=5
RETRIEVAL_FETCH_MULTIPLIER=20

TAVILY_API_KEY=tvly-...

# Token quota tiers (tokens/month) — override to customise subscription limits
OPENAI_MAX_TOKENS_PER_REQUEST=2000
TOKEN_QUOTA_STARTER=500000
TOKEN_QUOTA_PROFESSIONAL=2000000
TOKEN_QUOTA_ENTERPRISE=10000000

# Token cost rates (USD per 1k tokens) — set to match your LLM model's pricing
# Defaults: gpt-4o-mini ($0.15/1M input, $0.60/1M output)
TOKEN_COST_INPUT_PER_1K=0.00015
TOKEN_COST_OUTPUT_PER_1K=0.0006
